<Window x:Class="VideoEditorApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Video Editor" Height="600" Width="1000">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="File">
                <MenuItem Header="Open Main Video" Click="OpenMainVideo_Click"/>
                <MenuItem Header="Open Overlay Video" Click="OpenOverlayVideo_Click"/>
                <Separator/>
                <MenuItem Header="Export" Click="Export_Click"/>
            </MenuItem>
        </Menu>
        <ToolBar DockPanel.Dock="Top">
            <Button Content="Play" Click="Play_Click"/>
            <Button Content="Pause" Click="Pause_Click"/>
            <Button Content="Stop" Click="Stop_Click"/>
        </ToolBar>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
                <MediaElement Name="VideoPreview" LoadedBehavior="Manual"/>
                <Canvas Name="OverlayCanvas" IsHitTestVisible="False"/>
            </Grid>
            <StackPanel Grid.Column="1" Margin="10">
                <TextBlock Text="Text Overlay" Margin="0,0,0,5"/>
                <TextBox Name="OverlayText" Margin="0,0,0,5"/>
                <Button Content="Add Text" Click="AddTextButton_Click" Margin="0,0,0,10"/>
                <Separator/>
                <TextBlock Text="Effects" Margin="0,10,0,5"/>
                <ComboBox Name="EffectCombo" SelectedIndex="0" Margin="0,0,0,5">
                    <ComboBoxItem Content="None"/>
                    <ComboBoxItem Content="Grayscale"/>
                    <ComboBoxItem Content="FadeIn"/>
                </ComboBox>
                <Button Content="Apply Effect" Click="ApplyEffectButton_Click" Margin="0,0,0,10"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
